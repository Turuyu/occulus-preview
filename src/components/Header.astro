---
const navLinks = [
  { label: 'Inicio', href: '#' },
  { label: 'Portafolio', href: '#portfolio' },
  { label: 'Servicios', href: '#servicios' },
  { label: 'Acerca de', href: '#nosotros' },
  { label: 'Contacto', href: '#contacto' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-dark/90 backdrop-blur-sm">
  <nav class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="#" class="text-cream font-display text-2xl tracking-wider">
      MONOCROMO LAB
    </a>
    
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <li>
          <a 
            href={link.href}
            class="text-cream/80 hover:text-accent transition-colors text-sm uppercase tracking-widest"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    
    <button class="md:hidden text-cream" aria-label="Menú">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>
</header>
