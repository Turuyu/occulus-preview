---
const menuLinks = [
  { label: 'Inicio', href: '#' },
  { label: 'Portafolio', href: '#portfolio' },
  { label: 'Servicios', href: '#servicios' },
  { label: 'Acerca de', href: '#nosotros' },
  { label: 'Contacto', href: '#contacto' },
];

const socialLinks = [
  { label: 'Instagram', href: 'https://www.instagram.com/monocromolab_' },
  { label: 'Facebook', href: '#' },
  { label: 'WhatsApp', href: 'https://wa.me/529997820072' },
  { label: 'Email', href: 'mailto:contacto@monocromolab.com' },
];
---

<footer class="bg-dark text-cream py-16">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
      <!-- Logo -->
      <div>
        <a href="#" class="font-display text-3xl tracking-wider">
          MONOCROMO LAB
        </a>
        <p class="text-cream/60 text-sm mt-4 leading-relaxed">
          Creando recuerdos inolvidables. Retratos, eventos, producto y proposal sessions.
        </p>
      </div>
      
      <!-- Menú -->
      <div>
        <h4 class="uppercase tracking-widest text-xs text-cream/40 mb-4">Menú</h4>
        <ul class="space-y-2">
          {menuLinks.map((link) => (
            <li>
              <a href={link.href} class="text-cream/70 hover:text-accent transition-colors text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      <!-- Contacto -->
      <div>
        <h4 class="uppercase tracking-widest text-xs text-cream/40 mb-4">Contacto</h4>
        <address class="not-italic text-cream/70 text-sm space-y-2">
          <p>
            <a href="https://wa.me/529997820072" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">
              +52 999 782 0072
            </a>
          </p>
          <p>
            <a href="https://www.instagram.com/monocromolab_" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">
              @monocromolab_
            </a>
          </p>
          <p>
            <a href="mailto:contacto@monocromolab.com" class="hover:text-accent transition-colors">
              contacto@monocromolab.com
            </a>
          </p>
        </address>
      </div>
      
      <!-- Redes -->
      <div>
        <h4 class="uppercase tracking-widest text-xs text-cream/40 mb-4">Síguenos</h4>
        <ul class="space-y-2">
          {socialLinks.map((link) => (
            <li>
              <a href={link.href} target="_blank" rel="noopener noreferrer" class="text-cream/70 hover:text-accent transition-colors text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
    
    <div class="border-t border-cream/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-cream/40">
      <p>© 2026 MONOCROMO Lab. Todos los derechos reservados.</p>
      <div class="flex gap-6">
        <a href="#" class="hover:text-cream transition-colors">Privacidad</a>
        <a href="#" class="hover:text-cream transition-colors">Términos</a>
      </div>
    </div>
  </div>
</footer>
