---
const heroImage = 'https://images.unsplash.com/photo-1469334031218-e382a71b716b?w=1920&q=80';
---

<section class="relative h-screen flex items-end pb-20">
  <div class="absolute inset-0">
    <img 
      src={heroImage} 
      alt="MONOCROMO Lab - Creando recuerdos inolvidables"
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-dark/40" />
  </div>
  
  <div class="relative z-10 max-w-7xl mx-auto px-6 w-full">
    <p class="text-accent uppercase tracking-widest text-sm mb-4">MONOCROMO Lab</p>
    <h1 class="font-display text-5xl md:text-7xl lg:text-8xl text-cream leading-none mb-4">
      CREANDO<br />RECUERDOS<br />INOLVIDABLES
    </h1>
    <a 
      href="#portfolio"
      class="inline-block text-accent uppercase tracking-widest text-sm hover:text-cream transition-colors"
    >
      Ver más →
    </a>
  </div>
  
  <div class="absolute bottom-20 right-6 md:right-20 flex gap-3">
    <button class="w-10 h-10 rounded-full border border-cream/50 flex items-center justify-center text-cream hover:bg-cream hover:text-dark transition-all">
      ←
    </button>
    <button class="w-10 h-10 rounded-full border border-cream/50 flex items-center justify-center text-cream hover:bg-cream hover:text-dark transition-all">
      →
    </button>
  </div>
</section>
