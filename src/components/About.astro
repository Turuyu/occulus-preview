---
const aboutImage = 'https://images.unsplash.com/photo-1554048612-b6a482bc67e5?w=800&q=80';
const galleryImages = [
  'https://images.unsplash.com/photo-1509631179647-0177331693ae?w=400&q=80',
  'https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?w=400&q=80',
  'https://images.unsplash.com/photo-1529139574466-a303027c1d8b?w=400&q=80',
];
---

<section id="nosotros" class="bg-cream py-16 md:py-24">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 items-center">
      <!-- Imagen principal -->
      <div class="order-2 md:order-1">
        <div class="aspect-[3/4] overflow-hidden mb-4">
          <img 
            src={aboutImage} 
            alt="Juan Arana - Fotógrafo detrás de MONOCROMO Lab"
            class="w-full h-full object-cover"
          />
        </div>
        <!-- Mini gallery -->
        <div class="grid grid-cols-3 gap-2">
          {galleryImages.map((img) => (
            <div class="aspect-square overflow-hidden">
              <img 
                src={img} 
                alt=""
                class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500"
              />
            </div>
          ))}
        </div>
      </div>

      <!-- Texto -->
      <div class="order-1 md:order-2">
        <p class="text-accent uppercase tracking-widest text-xs mb-4">Acerca de</p>
        <h2 class="font-display text-4xl md:text-5xl text-dark leading-tight mb-8">
          Hola, soy <span class="italic">Juan Arana</span> y yo estoy detrás de MONOCROMO
        </h2>
        <div class="space-y-4 text-muted leading-relaxed">
          <p>
            Soy TEA con especialidad en Fotografía. Me gusta mucho retratar los momentos más felices e importantes para ti. La experimentación y creatividad siempre ha sido mi fortaleza.
          </p>
          <p class="font-display text-2xl text-dark italic">
            ¡Sonríe para la cámara!
          </p>
        </div>

        <!-- Instagram CTA -->
        <div class="mt-10 pt-8 border-t border-dark/10">
          <p class="text-xs uppercase tracking-widest text-muted mb-3">Sígueme en Instagram</p>
          <a 
            href="https://www.instagram.com/monocromolab_" 
            target="_blank" 
            rel="noopener noreferrer"
            class="text-dark font-display text-xl hover:text-accent transition-colors"
          >
            @monocromolab_
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
